// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id // Spotify user ID
  displayName    String
  email          String?
  avatarUrl      String?
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  playHistories  PlayHistory[]
  savedSessions  SavedSession[]
  savedTracks    UserSavedTrack[]

  @@map("users")
}

// Normalised track metadata — shared across all users
model Track {
  id          String   @id // Spotify track ID
  uri         String   @unique
  name        String
  artistNames String[]
  albumName   String
  albumArt    String
  durationMs  Int
  popularity  Int?     // 0-100; fetched from Spotify GET /tracks/:id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playHistories  PlayHistory[]
  savedByUsers   UserSavedTrack[]

  @@map("tracks")
}

model PlayHistory {
  id       String   @id @default(cuid())
  playedAt DateTime
  trackId  String
  userId   String

  track Track @relation(fields: [trackId], references: [id])
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, playedAt])
  @@index([userId, playedAt])
  @@map("play_histories")
}

// Per-user bookmarked tracks ("Save for Later")
model UserSavedTrack {
  id      String   @id @default(cuid())
  savedAt DateTime @default(now())
  userId  String
  trackId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id])

  @@unique([userId, trackId])
  @@index([userId])
  @@map("user_saved_tracks")
}

model SavedSession {
  id                 String   @id @default(cuid())
  name               String
  createdAt          DateTime @default(now())
  startTime          DateTime
  endTime            DateTime
  spotifyPlaylistId  String?
  spotifyPlaylistUrl String?
  trackUris          String[]
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareLinks         ShareLink[]

  @@index([userId])
  @@map("saved_sessions")
}

// Shareable deep-link tokens for saved sessions
model ShareLink {
  id               String          @id @default(cuid())
  token            String          @unique @default(cuid())
  savedSessionId   String
  visibility       ShareVisibility @default(PRIVATE)
  sharedWithUserId String?         // populated for SPECIFIC_USER grants
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())

  savedSession SavedSession @relation(fields: [savedSessionId], references: [id], onDelete: Cascade)

  @@index([savedSessionId])
  @@index([token])
  @@map("share_links")
}

enum ShareVisibility {
  PRIVATE
  LINK_ANYONE
  SPECIFIC_USER
}

model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}
