SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# IMPORTANT: Point this at the Vite dev server, not the backend port directly.
# Vite proxies /auth/callback → backend. This way the cookie is set on the same
# origin as the frontend (localhost:5173), so subsequent API calls include it.
SPOTIFY_REDIRECT_URI=http://localhost:5173/auth/callback

DATABASE_URL=postgresql://postgres:password@localhost:5432/sessions_db
SESSION_SECRET=your_super_secret_session_key_change_this
FRONTEND_URL=http://127.0.0.1:5173
PORT=3000
